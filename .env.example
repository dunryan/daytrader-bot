# Copy to .env and fill in. .env is git-ignored.

# ── Alpaca (data feed + live broker) ──
# Create free keys at https://alpaca.markets (use the PAPER keys).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── News / sentiment providers (Module 1) ──
# At least one is recommended; the engine degrades gracefully if absent.
FINNHUB_API_KEY=
NEWSAPI_API_KEY=

# ── Email (SMTP) for daily report (Module 6) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ── Optional alerting on kill-switch events ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
