# Alternative to the systemd service: drive each stage with cron.
# The in-process APScheduler (systemd) is recommended because it keeps one
# warm process and rehydrates state once. Use cron only if you prefer discrete
# invocations. Times below are the SERVER's local time — set CRON_TZ to your
# market timezone so they align with the NYSE session.
#
# Install:  crontab deploy/crontab.example   (after editing paths)

CRON_TZ=America/New_York
BOT=/opt/daytrader-bot

# Pre-market research at 07:00 ET, weekdays.
0 7 * * 1-5 cd $BOT && .venv/bin/python main.py --once research >> logs/cron.log 2>&1

# Trading cycle every minute during the session (09:31–15:59 ET), weekdays.
31-59 9 * * 1-5 cd $BOT && .venv/bin/python main.py --once trade >> logs/cron.log 2>&1
*    10-15 * * 1-5 cd $BOT && .venv/bin/python main.py --once trade >> logs/cron.log 2>&1

# Market-close flatten + report at 16:15 ET, weekdays.
15 16 * * 1-5 cd $BOT && .venv/bin/python main.py --once report >> logs/cron.log 2>&1
